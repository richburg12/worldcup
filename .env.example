# football-data.org API token (free tier). Register at:
# https://www.football-data.org/client/register
# Put the real value in .env.local (gitignored), not here.
FOOTBALL_DATA_TOKEN=

# Which competition to pull. WC = FIFA World Cup.
FOOTBALL_DATA_COMPETITION=WC

# Pin the season so the feed can't switch to a future tournament. Leave blank for "current".
FOOTBALL_DATA_SEASON=2026

# Set to 1 to freeze the site on the baked-in snapshot (no feed calls). Use after the final.
# FREEZE_BRACKET=1

# Public hit counter store (Upstash Redis via the Vercel Marketplace).
# Added automatically when you connect an Upstash store to the project on Vercel.
# If these are blank, the counter simply stays hidden — nothing breaks.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Prize contest (bracket predictions) ----

# Vercel Postgres. Added automatically when you connect a Postgres store on Vercel.
POSTGRES_URL=

# Resend (verification emails). Get the key at resend.com after verifying the sending domain.
RESEND_API_KEY=
# Must be an address on a domain verified in Resend. Sent from the restaurant so it reads as a
# promo from D GRANDE, not the personal site. "Name <address>" sets the friendly sender label.
EMAIL_FROM=D GRANDE Tex-Mex <info@dgrandetexmex.com>

# Public site URL used to build the confirmation link in emails.
NEXT_PUBLIC_BASE_URL=https://wecanjustmakeshitnow.com

# Shared secret for the /admin/contest page (any long random string).
ADMIN_TOKEN=

# Optional: override the entry cutoff for testing (ISO 8601). Defaults to 2026-07-04T17:00:00Z
# (first R16 kickoff, 6pm London). Set to a future time to test the entry flow before then.
# CONTEST_LOCK_ISO=
