# football-data.org API token (free tier). Register at:
# https://www.football-data.org/client/register
# Put the real value in .env.local (gitignored), not here.
FOOTBALL_DATA_TOKEN=

# Which competition to pull. WC = FIFA World Cup.
FOOTBALL_DATA_COMPETITION=WC

# Pin the season so the feed can't switch to a future tournament. Leave blank for "current".
FOOTBALL_DATA_SEASON=2026

# Set to 1 to freeze the site on the baked-in snapshot (no feed calls). Use after the final.
# FREEZE_BRACKET=1

# Public hit counter store (Upstash Redis via the Vercel Marketplace).
# Added automatically when you connect an Upstash store to the project on Vercel.
# If these are blank, the counter simply stays hidden — nothing breaks.
KV_REST_API_URL=
KV_REST_API_TOKEN=
